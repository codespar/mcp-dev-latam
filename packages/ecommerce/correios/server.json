{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.codespar/mcp-correios",
  "description": "MCP server for Correios — package tracking, shipping rates, CEP lookup",
  "repository": {
    "url": "https://github.com/codespar/mcp-dev-latam",
    "source": "github",
    "subfolder": "packages/ecommerce/correios"
  },
  "version": "0.2.0-alpha.2",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@codespar/mcp-correios",
      "version": "0.2.0-alpha.2",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "CORREIOS_TOKEN",
          "description": "API key for correios",
          "isRequired": true,
          "format": "string",
          "isSecret": true
        }
      ]
    }
  ],
  "provider": {
    "homepage": "https://www.correios.com.br",
    "logoUrl": "https://logo.clearbit.com/correios.com.br",
    "logoFallback": "https://www.google.com/s2/favicons?domain=correios.com.br&sz=128",
    "docsUrl": "https://www.correios.com.br/atendimento/desenvolvedores",
    "sandbox": {
      "available": true
    }
  }
}
