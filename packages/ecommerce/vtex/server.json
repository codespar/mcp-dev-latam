{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.codespar/mcp-vtex",
  "description": "MCP server for VTEX — e-commerce, orders, products, inventory, shipping",
  "repository": {
    "url": "https://github.com/codespar/mcp-dev-latam",
    "source": "github",
    "subfolder": "packages/ecommerce/vtex"
  },
  "version": "0.2.1",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@codespar/mcp-vtex",
      "version": "0.2.1",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "VTEX_APP_TOKEN",
          "description": "API key for vtex",
          "isRequired": true,
          "format": "string",
          "isSecret": true
        }
      ]
    }
  ],
  "provider": {
    "homepage": "https://www.vtex.com",
    "logoUrl": "https://logo.clearbit.com/vtex.com",
    "logoFallback": "https://www.google.com/s2/favicons?domain=vtex.com&sz=128",
    "docsUrl": "https://developers.vtex.com",
    "sandbox": {
      "available": true
    }
  }
}
