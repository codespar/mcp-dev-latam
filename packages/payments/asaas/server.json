{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.codespar/mcp-asaas",
  "description": "MCP server for Asaas — billing automation, Pix, boleto, credit card, subscriptions",
  "repository": {
    "url": "https://github.com/codespar/mcp-dev-latam",
    "source": "github",
    "subfolder": "packages/payments/asaas"
  },
  "version": "0.1.3",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@codespar/mcp-asaas",
      "version": "0.1.3",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "ASAAS_API_KEY",
          "description": "API key for asaas",
          "isRequired": true,
          "format": "string",
          "isSecret": true
        }
      ]
    }
  ],
  "provider": {
    "homepage": "https://www.asaas.com",
    "logoUrl": "https://logo.clearbit.com/asaas.com",
    "logoFallback": "https://www.google.com/s2/favicons?domain=asaas.com&sz=128",
    "docsUrl": "https://docs.asaas.com",
    "sandbox": {
      "available": true,
      "url": "https://sandbox.asaas.com/api/v3"
    }
  }
}
