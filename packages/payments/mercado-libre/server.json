{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.codespar/mcp-mercado-libre",
  "description": "Mercado Libre — LATAM marketplace, product search, orders, sellers, shipments",
  "repository": {
    "url": "https://github.com/codespar/mcp-dev-latam",
    "source": "github",
    "subfolder": "packages/payments/mercado-libre"
  },
  "version": "0.2.1",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@codespar/mcp-mercado-libre",
      "version": "0.2.1",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "MELI_ACCESS_TOKEN",
          "description": "API key/token for mercado-libre",
          "isRequired": true,
          "format": "string",
          "isSecret": true
        }
      ]
    }
  ],
  "provider": {
    "homepage": "https://www.mercadolibre.com.ar",
    "logoUrl": "https://logo.clearbit.com/mercadolibre.com.ar",
    "logoFallback": "https://www.google.com/s2/favicons?domain=mercadolibre.com.ar&sz=128",
    "docsUrl": "https://developers.mercadolibre.com.ar",
    "sandbox": {
      "available": true
    }
  }
}
