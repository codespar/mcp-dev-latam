{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.codespar/mcp-rede",
  "description": "MCP server for Rede — Itaú-owned Brazilian card acquirer. Authorize/capture/refund, zero-auth, card tokens, and native recurrences.",
  "repository": {
    "url": "https://github.com/codespar/mcp-dev-latam",
    "source": "github",
    "subfolder": "packages/payments/rede"
  },
  "version": "0.2.0-alpha.2",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@codespar/mcp-rede",
      "version": "0.2.0-alpha.2",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "REDE_PV",
          "description": "Rede merchant filiação (PV) — numeric merchant identifier issued with your commercial contract.",
          "isRequired": true,
          "format": "string",
          "isSecret": false
        },
        {
          "name": "REDE_TOKEN",
          "description": "Rede API security token paired with PV. Used in HTTP Basic auth as the password.",
          "isRequired": true,
          "format": "string",
          "isSecret": true
        },
        {
          "name": "REDE_ENV",
          "description": "Environment selector: 'sandbox' (default) or 'production'.",
          "isRequired": false,
          "format": "string",
          "isSecret": false
        }
      ]
    }
  ],
  "provider": {
    "homepage": "https://www.userede.com.br",
    "logoUrl": "https://logo.clearbit.com/userede.com.br",
    "logoFallback": "https://www.google.com/s2/favicons?domain=userede.com.br&sz=128",
    "docsUrl": "https://www.userede.com.br/desenvolvedores",
    "sandbox": {
      "available": true
    }
  }
}
