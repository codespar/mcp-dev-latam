{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.codespar/mcp-ebanx",
  "description": "MCP server for EBANX — cross-border payments, payouts, exchange rates",
  "repository": {
    "url": "https://github.com/codespar/mcp-dev-latam",
    "source": "github",
    "subfolder": "packages/payments/ebanx"
  },
  "version": "0.2.1",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@codespar/mcp-ebanx",
      "version": "0.2.1",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "EBANX_API_KEY",
          "description": "API key for ebanx",
          "isRequired": true,
          "format": "string",
          "isSecret": true
        }
      ]
    }
  ],
  "provider": {
    "homepage": "https://www.ebanx.com",
    "logoUrl": "https://logo.clearbit.com/ebanx.com",
    "logoFallback": "https://www.google.com/s2/favicons?domain=ebanx.com&sz=128",
    "docsUrl": "https://developers.ebanx.com",
    "sandbox": {
      "available": true
    }
  }
}
