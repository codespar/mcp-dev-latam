{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.codespar/mcp-celcoin",
  "description": "MCP server for Celcoin — Pix, boleto, transfers, bill payments, top-ups",
  "repository": {
    "url": "https://github.com/codespar/mcp-dev-brasil",
    "source": "github",
    "subfolder": "packages/payments/celcoin"
  },
  "version": "0.2.1",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@codespar/mcp-celcoin",
      "version": "0.2.1",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "CELCOIN_CLIENT_SECRET",
          "description": "API key for celcoin",
          "isRequired": true,
          "format": "string",
          "isSecret": true
        }
      ]
    }
  ]
}
