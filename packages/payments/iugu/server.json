{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.codespar/mcp-iugu",
  "description": "MCP server for iugu — invoices, subscriptions, customers, payment methods",
  "repository": {
    "url": "https://github.com/codespar/mcp-dev-latam",
    "source": "github",
    "subfolder": "packages/payments/iugu"
  },
  "version": "0.2.1",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@codespar/mcp-iugu",
      "version": "0.2.1",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "IUGU_API_TOKEN",
          "description": "API key for iugu",
          "isRequired": true,
          "format": "string",
          "isSecret": true
        }
      ]
    }
  ],
  "provider": {
    "homepage": "https://www.iugu.com",
    "logoUrl": "https://logo.clearbit.com/iugu.com",
    "logoFallback": "https://www.google.com/s2/favicons?domain=iugu.com&sz=128",
    "docsUrl": "https://dev.iugu.com",
    "sandbox": {
      "available": true
    }
  }
}
