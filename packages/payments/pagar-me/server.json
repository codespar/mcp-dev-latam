{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.codespar/mcp-pagar-me",
  "description": "MCP server for Pagar.me — orders, charges, recipients, transfers, anticipations, plans, subscriptions, tokens, withdrawals, webhooks",
  "repository": {
    "url": "https://github.com/codespar/mcp-dev-latam",
    "source": "github",
    "subfolder": "packages/payments/pagar-me"
  },
  "version": "0.2.1",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@codespar/mcp-pagar-me",
      "version": "0.2.1",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "PAGARME_API_KEY",
          "description": "Secret key (sk_xxx) for Pagar.me",
          "isRequired": true,
          "format": "string",
          "isSecret": true
        },
        {
          "name": "PAGARME_PUBLIC_KEY",
          "description": "Public key (pk_xxx) for card tokenization (required only for create_card_token)",
          "isRequired": false,
          "format": "string",
          "isSecret": false
        }
      ]
    }
  ],
  "provider": {
    "homepage": "https://www.pagar.me",
    "logoUrl": "https://logo.clearbit.com/pagar.me",
    "logoFallback": "https://www.google.com/s2/favicons?domain=pagar.me&sz=128",
    "docsUrl": "https://docs.pagar.me",
    "sandbox": {
      "available": true
    }
  }
}
