{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.codespar/mcp-mercado-pago",
  "description": "Mercado Pago — payments, checkout, PIX, refunds for LATAM",
  "repository": {
    "url": "https://github.com/codespar/mcp-dev-latam",
    "source": "github",
    "subfolder": "packages/payments/mercado-pago"
  },
  "version": "0.2.1",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@codespar/mcp-mercado-pago",
      "version": "0.2.1",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "MERCADO_PAGO_ACCESS_TOKEN",
          "description": "API key/token for mercado-pago",
          "isRequired": true,
          "format": "string",
          "isSecret": true
        }
      ]
    }
  ],
  "provider": {
    "homepage": "https://www.mercadopago.com.br",
    "logoUrl": "https://logo.clearbit.com/mercadopago.com.br",
    "logoFallback": "https://www.google.com/s2/favicons?domain=mercadopago.com.br&sz=128",
    "docsUrl": "https://www.mercadopago.com.br/developers",
    "sandbox": {
      "available": true
    }
  }
}
