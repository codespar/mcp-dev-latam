{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.codespar/mcp-zoop",
  "description": "MCP server for Zoop — marketplace payments, splits, sellers, buyers, transfers",
  "repository": {
    "url": "https://github.com/codespar/mcp-dev-latam",
    "source": "github",
    "subfolder": "packages/payments/zoop"
  },
  "version": "0.1.3",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@codespar/mcp-zoop",
      "version": "0.1.3",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "ZOOP_API_KEY",
          "description": "API key for zoop",
          "isRequired": true,
          "format": "string",
          "isSecret": true
        }
      ]
    }
  ],
  "provider": {
    "homepage": "https://www.zoop.com.br",
    "logoUrl": "https://logo.clearbit.com/zoop.com.br",
    "logoFallback": "https://www.google.com/s2/favicons?domain=zoop.com.br&sz=128",
    "docsUrl": "https://docs.zoop.co",
    "sandbox": {
      "available": true
    }
  }
}
