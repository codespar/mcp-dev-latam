{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.codespar/mcp-vindi",
  "description": "MCP server for Vindi — recurring billing, subscriptions, invoices",
  "repository": {
    "url": "https://github.com/codespar/mcp-dev-latam",
    "source": "github",
    "subfolder": "packages/payments/vindi"
  },
  "version": "0.2.1",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@codespar/mcp-vindi",
      "version": "0.2.1",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "VINDI_API_KEY",
          "description": "API key for vindi",
          "isRequired": true,
          "format": "string",
          "isSecret": true
        }
      ]
    }
  ],
  "provider": {
    "homepage": "https://www.vindi.com.br",
    "logoUrl": "https://logo.clearbit.com/vindi.com.br",
    "logoFallback": "https://www.google.com/s2/favicons?domain=vindi.com.br&sz=128",
    "docsUrl": "https://vindi.github.io/api-docs",
    "sandbox": {
      "available": false
    }
  }
}
