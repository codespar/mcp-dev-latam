{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.codespar/mcp-cielo",
  "description": "MCP server for Cielo — credit card, debit, boleto, recurrent payments",
  "repository": {
    "url": "https://github.com/codespar/mcp-dev-brasil",
    "source": "github",
    "subfolder": "packages/payments/cielo"
  },
  "version": "0.1.2",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@codespar/mcp-cielo",
      "version": "0.1.2",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "CIELO_API_KEY",
          "description": "API key for cielo",
          "isRequired": true,
          "format": "string",
          "isSecret": true
        }
      ]
    }
  ]
}
