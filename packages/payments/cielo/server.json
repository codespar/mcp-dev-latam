{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.codespar/mcp-cielo",
  "description": "MCP server for Cielo — credit card, debit, boleto, recurrent payments",
  "repository": {
    "url": "https://github.com/codespar/mcp-dev-latam",
    "source": "github",
    "subfolder": "packages/payments/cielo"
  },
  "version": "0.2.1",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@codespar/mcp-cielo",
      "version": "0.2.1",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "CIELO_API_KEY",
          "description": "API key for cielo",
          "isRequired": true,
          "format": "string",
          "isSecret": true
        }
      ]
    }
  ],
  "provider": {
    "homepage": "https://www.cielo.com.br",
    "logoUrl": "https://logo.clearbit.com/cielo.com.br",
    "logoFallback": "https://www.google.com/s2/favicons?domain=cielo.com.br&sz=128",
    "docsUrl": "https://developercielo.github.io",
    "sandbox": {
      "available": true
    }
  }
}
