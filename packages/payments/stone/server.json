{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.codespar/mcp-stone",
  "description": "MCP server for Stone — open banking, payments, Pix, transfers",
  "repository": {
    "url": "https://github.com/codespar/mcp-dev-latam",
    "source": "github",
    "subfolder": "packages/payments/stone"
  },
  "version": "0.2.1",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@codespar/mcp-stone",
      "version": "0.2.1",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "STONE_CLIENT_SECRET",
          "description": "API key for stone",
          "isRequired": true,
          "format": "string",
          "isSecret": true
        }
      ]
    }
  ],
  "provider": {
    "homepage": "https://www.stone.com.br",
    "logoUrl": "https://logo.clearbit.com/stone.com.br",
    "logoFallback": "https://www.google.com/s2/favicons?domain=stone.com.br&sz=128",
    "docsUrl": "https://developer.stone.com.br",
    "sandbox": {
      "available": true
    }
  }
}
