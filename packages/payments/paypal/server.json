{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.codespar/mcp-paypal",
  "description": "MCP server for PayPal — global payments and payouts via REST API. Orders v2, Payments v2, Payouts, Subscriptions, Disputes, Webhooks.",
  "repository": {
    "url": "https://github.com/codespar/mcp-dev-latam",
    "source": "github",
    "subfolder": "packages/payments/paypal"
  },
  "version": "0.1.1",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@codespar/mcp-paypal",
      "version": "0.1.1",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "PAYPAL_CLIENT_ID",
          "description": "PayPal REST app client id (from developer.paypal.com Apps & Credentials).",
          "isRequired": true,
          "format": "string",
          "isSecret": false
        },
        {
          "name": "PAYPAL_CLIENT_SECRET",
          "description": "PayPal REST app client secret (OAuth2 client_credentials password).",
          "isRequired": true,
          "format": "string",
          "isSecret": true
        },
        {
          "name": "PAYPAL_ENV",
          "description": "PayPal environment. 'sandbox' (default, https://api-m.sandbox.paypal.com) or 'live' (https://api-m.paypal.com).",
          "isRequired": false,
          "format": "string",
          "isSecret": false
        }
      ]
    }
  ],
  "provider": {
    "homepage": "https://www.paypal.com",
    "logoUrl": "https://logo.clearbit.com/paypal.com",
    "logoFallback": "https://www.google.com/s2/favicons?domain=paypal.com&sz=128",
    "docsUrl": "https://developer.paypal.com/api",
    "sandbox": {
      "available": true
    }
  }
}
