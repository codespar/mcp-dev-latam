{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.codespar/mcp-stripe-acp",
  "description": "Stripe ACP — AI agent checkout, payment delegation, products, invoices",
  "repository": {
    "url": "https://github.com/codespar/mcp-dev-latam",
    "source": "github",
    "subfolder": "packages/payments/stripe-acp"
  },
  "version": "0.1.3",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@codespar/mcp-stripe-acp",
      "version": "0.1.3",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "STRIPE_API_KEY",
          "description": "API key for stripe-acp",
          "isRequired": true,
          "format": "string",
          "isSecret": true
        }
      ]
    }
  ],
  "provider": {
    "homepage": "https://www.stripe.com",
    "logoUrl": "https://logo.clearbit.com/stripe.com",
    "logoFallback": "https://www.google.com/s2/favicons?domain=stripe.com&sz=128",
    "docsUrl": "https://docs.stripe.com/agents",
    "sandbox": {
      "available": true
    }
  }
}
