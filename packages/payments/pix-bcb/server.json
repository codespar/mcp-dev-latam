{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.codespar/mcp-pix-bcb",
  "description": "MCP server for Pix BCB API — official Banco Central do Brasil Pix standard",
  "repository": {
    "url": "https://github.com/codespar/mcp-dev-latam",
    "source": "github",
    "subfolder": "packages/payments/pix-bcb"
  },
  "version": "0.2.1",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@codespar/mcp-pix-bcb",
      "version": "0.2.1",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "PIX_CLIENT_SECRET",
          "description": "API key for pix-bcb",
          "isRequired": true,
          "format": "string",
          "isSecret": true
        }
      ]
    }
  ],
  "provider": {
    "homepage": "https://www.bcb.gov.br",
    "logoUrl": "https://logo.clearbit.com/bcb.gov.br",
    "logoFallback": "https://www.google.com/s2/favicons?domain=bcb.gov.br&sz=128",
    "docsUrl": "https://www.bcb.gov.br/estabilidadefinanceira/pix",
    "sandbox": {
      "available": true
    }
  }
}
