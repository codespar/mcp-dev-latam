{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.codespar/mcp-airwallex",
  "description": "MCP server for Airwallex — embedded finance for cross-border collection and payouts. Global accounts, FX conversions, beneficiary transfers.",
  "repository": {
    "url": "https://github.com/codespar/mcp-dev-latam",
    "source": "github",
    "subfolder": "packages/payments/airwallex"
  },
  "version": "0.2.1",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@codespar/mcp-airwallex",
      "version": "0.2.1",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "AIRWALLEX_CLIENT_ID",
          "description": "Airwallex client id (sent as x-client-id on /authentication/login)",
          "isRequired": true,
          "format": "string",
          "isSecret": false
        },
        {
          "name": "AIRWALLEX_API_KEY",
          "description": "Airwallex API key, secret (sent as x-api-key on /authentication/login)",
          "isRequired": true,
          "format": "string",
          "isSecret": true
        },
        {
          "name": "AIRWALLEX_ENV",
          "description": "Airwallex environment. 'demo' (default, https://api-demo.airwallex.com) or 'production' (https://api.airwallex.com).",
          "isRequired": false,
          "format": "string",
          "isSecret": false
        }
      ]
    }
  ],
  "provider": {
    "homepage": "https://www.airwallex.com",
    "logoUrl": "https://logo.clearbit.com/airwallex.com",
    "logoFallback": "https://www.google.com/s2/favicons?domain=airwallex.com&sz=128",
    "docsUrl": "https://www.airwallex.com/docs",
    "sandbox": {
      "available": true
    }
  }
}
