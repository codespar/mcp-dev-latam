{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.codespar/mcp-inter-bank",
  "description": "Banco Inter — digital bank, boleto, PIX, statements, transfers",
  "repository": {
    "url": "https://github.com/codespar/mcp-dev-brasil",
    "source": "github",
    "subfolder": "packages/payments/inter-bank"
  },
  "version": "0.2.0",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@codespar/mcp-inter-bank",
      "version": "0.2.0",
      "transport": { "type": "stdio" },
      "environmentVariables": [
        {
          "name": "INTER_CLIENT_ID",
          "description": "API key/token for inter-bank",
          "isRequired": true,
          "format": "string",
          "isSecret": true
        }
      ]
    }
  ]
}
