{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.codespar/mcp-culqi",
  "description": "MCP server for Culqi — Peru's default PSP. Charges, refunds, customers, cards, orders (Yape / PagoEfectivo), plans, subscriptions, events.",
  "repository": {
    "url": "https://github.com/codespar/mcp-dev-latam",
    "source": "github",
    "subfolder": "packages/payments/culqi"
  },
  "version": "0.2.1",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@codespar/mcp-culqi",
      "version": "0.2.1",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "CULQI_SECRET_KEY",
          "description": "Culqi secret key. Use sk_test_... for sandbox, sk_live_... for production.",
          "isRequired": true,
          "format": "string",
          "isSecret": true
        }
      ]
    }
  ],
  "provider": {
    "homepage": "https://www.culqi.com",
    "logoUrl": "https://logo.clearbit.com/culqi.com",
    "logoFallback": "https://www.google.com/s2/favicons?domain=culqi.com&sz=128",
    "docsUrl": "https://docs.culqi.com",
    "sandbox": {
      "available": true
    }
  }
}
