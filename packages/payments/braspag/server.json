{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.codespar/mcp-braspag",
  "description": "MCP server for Braspag — Cielo's enterprise orchestration, token vault (Cartão Protegido), recurrence, and marketplace split",
  "repository": {
    "url": "https://github.com/codespar/mcp-dev-brasil",
    "source": "github",
    "subfolder": "packages/payments/braspag"
  },
  "version": "0.2.0",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@codespar/mcp-braspag",
      "version": "0.2.0",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "BRASPAG_MERCHANT_ID",
          "description": "Braspag MerchantId (UUID)",
          "isRequired": true,
          "format": "string",
          "isSecret": true
        },
        {
          "name": "BRASPAG_MERCHANT_KEY",
          "description": "Braspag MerchantKey (secret)",
          "isRequired": true,
          "format": "string",
          "isSecret": true
        },
        {
          "name": "BRASPAG_ENV",
          "description": "Environment: 'sandbox' or 'production'. Defaults to 'sandbox'.",
          "isRequired": false,
          "format": "string",
          "isSecret": false
        }
      ]
    }
  ]
}
