{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.codespar/mcp-braspag",
  "description": "MCP server for Braspag — Cielo's enterprise orchestration, token vault (Cartão Protegido), recurrence, and marketplace split",
  "repository": {
    "url": "https://github.com/codespar/mcp-dev-latam",
    "source": "github",
    "subfolder": "packages/payments/braspag"
  },
  "version": "0.2.1",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@codespar/mcp-braspag",
      "version": "0.2.1",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "BRASPAG_MERCHANT_ID",
          "description": "Braspag MerchantId (UUID)",
          "isRequired": true,
          "format": "string",
          "isSecret": true
        },
        {
          "name": "BRASPAG_MERCHANT_KEY",
          "description": "Braspag MerchantKey (secret)",
          "isRequired": true,
          "format": "string",
          "isSecret": true
        },
        {
          "name": "BRASPAG_ENV",
          "description": "Environment: 'sandbox' or 'production'. Defaults to 'sandbox'.",
          "isRequired": false,
          "format": "string",
          "isSecret": false
        }
      ]
    }
  ],
  "provider": {
    "homepage": "https://www.braspag.com.br",
    "logoUrl": "https://logo.clearbit.com/braspag.com.br",
    "logoFallback": "https://www.google.com/s2/favicons?domain=braspag.com.br&sz=128",
    "docsUrl": "https://braspag.github.io",
    "sandbox": {
      "available": true
    }
  }
}
