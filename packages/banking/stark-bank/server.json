{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.codespar/mcp-stark-bank",
  "description": "MCP server for Stark Bank — transfers, boletos, invoices, Pix, balance",
  "repository": {
    "url": "https://github.com/codespar/mcp-dev-latam",
    "source": "github",
    "subfolder": "packages/banking/stark-bank"
  },
  "version": "0.2.1",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@codespar/mcp-stark-bank",
      "version": "0.2.1",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "STARK_BANK_ACCESS_TOKEN",
          "description": "API key for stark-bank",
          "isRequired": true,
          "format": "string",
          "isSecret": true
        }
      ]
    }
  ],
  "provider": {
    "homepage": "https://www.starkbank.com",
    "logoUrl": "https://logo.clearbit.com/starkbank.com",
    "logoFallback": "https://www.google.com/s2/favicons?domain=starkbank.com&sz=128",
    "docsUrl": "https://starkbank.com/docs",
    "sandbox": {
      "available": true
    }
  }
}
