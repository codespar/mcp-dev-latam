{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.codespar/mcp-pluggy",
  "description": "MCP server for Pluggy — Open Finance Brasil aggregator. ITP/TPP that holds the ICP-Brasil cert + runs DCR with each Brazilian bank, exposing a single API for account discovery, transactions, payments initiation.",
  "repository": {
    "url": "https://github.com/codespar/mcp-dev-latam",
    "source": "github",
    "subfolder": "packages/banking/pluggy"
  },
  "version": "0.0.1-alpha",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@codespar/mcp-pluggy",
      "version": "0.0.1-alpha",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "PLUGGY_CLIENT_ID",
          "description": "Pluggy client ID issued at https://dashboard.pluggy.ai",
          "isRequired": true,
          "format": "string",
          "isSecret": true
        },
        {
          "name": "PLUGGY_CLIENT_SECRET",
          "description": "Pluggy client secret",
          "isRequired": true,
          "format": "string",
          "isSecret": true
        }
      ]
    }
  ],
  "provider": {
    "homepage": "https://www.pluggy.ai/en",
    "logoUrl": "https://logo.clearbit.com/pluggy.ai",
    "logoFallback": "https://www.google.com/s2/favicons?domain=pluggy.ai&sz=128",
    "docsUrl": "https://docs.pluggy.ai",
    "sandbox": {
      "available": true,
      "url": "https://api.pluggy.ai"
    }
  }
}
