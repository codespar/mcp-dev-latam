{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.codespar/mcp-iniciador",
  "description": "MCP server for Iniciador — Open Finance Brasil aggregator focused on Pix payment initiation (PISP). Hosts the ICP-Brasil cert and orchestrates DCR with each Brazilian bank for instant Pix-out.",
  "repository": {
    "url": "https://github.com/codespar/mcp-dev-latam",
    "source": "github",
    "subfolder": "packages/banking/iniciador"
  },
  "version": "0.0.1-alpha",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@codespar/mcp-iniciador",
      "version": "0.0.1-alpha",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "INICIADOR_CLIENT_ID",
          "description": "Iniciador OAuth2 client ID",
          "isRequired": true,
          "format": "string",
          "isSecret": true
        },
        {
          "name": "INICIADOR_CLIENT_SECRET",
          "description": "Iniciador OAuth2 client secret",
          "isRequired": true,
          "format": "string",
          "isSecret": true
        },
        {
          "name": "INICIADOR_API_BASE",
          "description": "API base URL — defaults to Iniciador production. Override for sandbox.",
          "isRequired": false,
          "format": "string",
          "isSecret": false
        }
      ]
    }
  ],
  "provider": {
    "homepage": "https://iniciador.com.br",
    "logoUrl": "https://logo.clearbit.com/iniciador.com.br",
    "logoFallback": "https://www.google.com/s2/favicons?domain=iniciador.com.br&sz=128",
    "docsUrl": "https://docs.iniciador.com.br",
    "sandbox": {
      "available": true,
      "url": "https://sandbox.iniciador.com.br"
    }
  }
}
