{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.codespar/mcp-x402",
  "description": "MCP server for x402 — HTTP-native micropayments protocol by Coinbase (USDC on Base/Solana)",
  "repository": {
    "url": "https://github.com/codespar/mcp-dev-latam",
    "source": "github",
    "subfolder": "packages/crypto/x402"
  },
  "version": "0.1.3",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@codespar/mcp-x402",
      "version": "0.1.3",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "X402_API_KEY",
          "description": "API key for x402",
          "isRequired": true,
          "format": "string",
          "isSecret": true
        }
      ]
    }
  ],
  "provider": {
    "homepage": "https://www.x402.org",
    "logoUrl": "https://logo.clearbit.com/x402.org",
    "logoFallback": "https://www.google.com/s2/favicons?domain=x402.org&sz=128",
    "docsUrl": "https://x402.org",
    "sandbox": {
      "available": true
    }
  }
}
