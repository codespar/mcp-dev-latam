{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.codespar/mcp-x402",
  "description": "MCP server for x402 — HTTP-native micropayments protocol by Coinbase (USDC on Base/Solana)",
  "repository": {
    "url": "https://github.com/codespar/mcp-dev-brasil",
    "source": "github",
    "subfolder": "packages/crypto/x402"
  },
  "version": "0.1.3",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@codespar/mcp-x402",
      "version": "0.1.3",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "X402_API_KEY",
          "description": "API key for x402",
          "isRequired": true,
          "format": "string",
          "isSecret": true
        }
      ]
    }
  ]
}
