{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.codespar/mcp-mercado-bitcoin",
  "description": "MCP server for Mercado Bitcoin — Brazilian crypto exchange, trading, orderbook, withdrawals",
  "repository": {
    "url": "https://github.com/codespar/mcp-dev-latam",
    "source": "github",
    "subfolder": "packages/crypto/mercado-bitcoin"
  },
  "version": "0.2.1",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@codespar/mcp-mercado-bitcoin",
      "version": "0.2.1",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "MB_API_KEY",
          "description": "API key for mercado-bitcoin",
          "isRequired": true,
          "format": "string",
          "isSecret": true
        }
      ]
    }
  ],
  "provider": {
    "homepage": "https://www.mercadobitcoin.com.br",
    "logoUrl": "https://logo.clearbit.com/mercadobitcoin.com.br",
    "logoFallback": "https://www.google.com/s2/favicons?domain=mercadobitcoin.com.br&sz=128",
    "docsUrl": "https://api.mercadobitcoin.net/api/v4/docs",
    "sandbox": {
      "available": false
    }
  }
}
