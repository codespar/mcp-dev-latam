{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.codespar/mcp-nuvem-fiscal",
  "description": "MCP server for Nuvem Fiscal — NF-e, NFS-e, NFC-e, CNPJ, CEP",
  "repository": {
    "url": "https://github.com/codespar/mcp-dev-brasil",
    "source": "github",
    "subfolder": "packages/fiscal/nuvem-fiscal"
  },
  "version": "0.2.1",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@codespar/mcp-nuvem-fiscal",
      "version": "0.2.1",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "NUVEM_FISCAL_CLIENT_SECRET",
          "description": "API key for nuvem-fiscal",
          "isRequired": true,
          "format": "string",
          "isSecret": true
        }
      ]
    }
  ]
}
