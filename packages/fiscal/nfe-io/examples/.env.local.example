# Copy this file to .env.local and fill in your NFe.io sandbox credentials.
# .env.local is gitignored at the repo root, so your secrets won't ship.

# NFe.io API key (single key with issuance + query scopes; or split into two).
# Find it in the NFe.io dashboard → Configurações → API Access.
NFEIO_API_KEY=

# Default company id (a UUID-looking string) OR the company's CNPJ (14 digits).
# Per-call `company_id` arguments in tool invocations override this.
NFEIO_COMPANY_ID=
