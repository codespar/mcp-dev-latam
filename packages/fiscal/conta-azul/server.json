{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.codespar/mcp-conta-azul",
  "description": "MCP server for Conta Azul — accounting, invoicing, customers, products",
  "repository": {
    "url": "https://github.com/codespar/mcp-dev-latam",
    "source": "github",
    "subfolder": "packages/fiscal/conta-azul"
  },
  "version": "0.2.1",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@codespar/mcp-conta-azul",
      "version": "0.2.1",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "CONTA_AZUL_ACCESS_TOKEN",
          "description": "API key for conta-azul",
          "isRequired": true,
          "format": "string",
          "isSecret": true
        }
      ]
    }
  ],
  "provider": {
    "homepage": "https://www.contaazul.com",
    "logoUrl": "https://logo.clearbit.com/contaazul.com",
    "logoFallback": "https://www.google.com/s2/favicons?domain=contaazul.com&sz=128",
    "docsUrl": "https://developers.contaazul.com",
    "sandbox": {
      "available": true
    }
  }
}
