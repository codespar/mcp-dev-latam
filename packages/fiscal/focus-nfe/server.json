{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.codespar/mcp-focus-nfe",
  "description": "MCP server for Focus NFe — NFe, NFSe, NFCe emission and management",
  "repository": {
    "url": "https://github.com/codespar/mcp-dev-latam",
    "source": "github",
    "subfolder": "packages/fiscal/focus-nfe"
  },
  "version": "0.2.1",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@codespar/mcp-focus-nfe",
      "version": "0.2.1",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "FOCUS_NFE_TOKEN",
          "description": "API key for focus-nfe",
          "isRequired": true,
          "format": "string",
          "isSecret": true
        }
      ]
    }
  ],
  "provider": {
    "homepage": "https://www.focusnfe.com.br",
    "logoUrl": "https://logo.clearbit.com/focusnfe.com.br",
    "logoFallback": "https://www.google.com/s2/favicons?domain=focusnfe.com.br&sz=128",
    "docsUrl": "https://focusnfe.com.br/doc",
    "sandbox": {
      "available": true
    }
  }
}
