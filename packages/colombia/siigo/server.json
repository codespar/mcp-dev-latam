{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.codespar/mcp-siigo",
  "description": "Siigo — Colombian accounting + DIAN e-invoicing",
  "repository": {
    "url": "https://github.com/codespar/mcp-dev-latam",
    "source": "github",
    "subfolder": "packages/colombia/siigo"
  },
  "version": "0.2.1",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@codespar/mcp-siigo",
      "version": "0.2.1",
      "transport": { "type": "stdio" },
      "environmentVariables": [
        {
          "name": "SIIGO_API_KEY",
          "description": "API key for Siigo",
          "isRequired": true,
          "format": "string",
          "isSecret": true
        },
        {
          "name": "SIIGO_ACCESS_TOKEN",
          "description": "Bearer access token",
          "isRequired": true,
          "format": "string",
          "isSecret": true
        }
      ]
    }
  ]
}
