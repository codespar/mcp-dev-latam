{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.codespar/mcp-alegra",
  "description": "Alegra — cloud accounting for LATAM (Colombian-founded)",
  "repository": {
    "url": "https://github.com/codespar/mcp-dev-latam",
    "source": "github",
    "subfolder": "packages/colombia/alegra"
  },
  "version": "0.2.1",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@codespar/mcp-alegra",
      "version": "0.2.1",
      "transport": { "type": "stdio" },
      "environmentVariables": [
        {
          "name": "ALEGRA_EMAIL",
          "description": "Account email for Alegra",
          "isRequired": true,
          "format": "string",
          "isSecret": false
        },
        {
          "name": "ALEGRA_API_TOKEN",
          "description": "API token for Alegra",
          "isRequired": true,
          "format": "string",
          "isSecret": true
        }
      ]
    }
  ]
}
