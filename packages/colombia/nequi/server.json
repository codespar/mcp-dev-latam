{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.codespar/mcp-nequi",
  "description": "Nequi — Colombian digital wallet (50M+ users, by Bancolombia)",
  "repository": {
    "url": "https://github.com/codespar/mcp-dev-latam",
    "source": "github",
    "subfolder": "packages/colombia/nequi"
  },
  "version": "0.1.0",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@codespar/mcp-nequi",
      "version": "0.1.0",
      "transport": { "type": "stdio" },
      "environmentVariables": [
        {
          "name": "NEQUI_API_KEY",
          "description": "API key for Nequi",
          "isRequired": true,
          "format": "string",
          "isSecret": true
        },
        {
          "name": "NEQUI_CLIENT_ID",
          "description": "OAuth2 client ID",
          "isRequired": true,
          "format": "string",
          "isSecret": false
        },
        {
          "name": "NEQUI_CLIENT_SECRET",
          "description": "OAuth2 client secret",
          "isRequired": true,
          "format": "string",
          "isSecret": true
        }
      ]
    }
  ]
}
