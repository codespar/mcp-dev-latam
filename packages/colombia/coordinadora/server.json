{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.codespar/mcp-coordinadora",
  "description": "Coordinadora — Colombian courier and logistics",
  "repository": {
    "url": "https://github.com/codespar/mcp-dev-latam",
    "source": "github",
    "subfolder": "packages/colombia/coordinadora"
  },
  "version": "0.2.0-alpha.2",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@codespar/mcp-coordinadora",
      "version": "0.2.0-alpha.2",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "COORDINADORA_API_KEY",
          "description": "API key for Coordinadora",
          "isRequired": true,
          "format": "string",
          "isSecret": true
        },
        {
          "name": "COORDINADORA_NIT",
          "description": "Company NIT number",
          "isRequired": true,
          "format": "string",
          "isSecret": false
        }
      ]
    }
  ],
  "provider": {
    "homepage": "https://www.coordinadora.com",
    "logoUrl": "https://logo.clearbit.com/coordinadora.com",
    "logoFallback": "https://www.google.com/s2/favicons?domain=coordinadora.com&sz=128",
    "docsUrl": "https://coordinadora.docs.apiary.io",
    "sandbox": {
      "available": true
    }
  }
}
