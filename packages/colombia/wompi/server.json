{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.codespar/mcp-wompi",
  "description": "Wompi — Colombian payment gateway (by Bancolombia)",
  "repository": {
    "url": "https://github.com/codespar/mcp-dev-latam",
    "source": "github",
    "subfolder": "packages/colombia/wompi"
  },
  "version": "0.2.0",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@codespar/mcp-wompi",
      "version": "0.2.0",
      "transport": { "type": "stdio" },
      "environmentVariables": [
        {
          "name": "WOMPI_PUBLIC_KEY",
          "description": "Public key for Wompi",
          "isRequired": true,
          "format": "string",
          "isSecret": false
        },
        {
          "name": "WOMPI_PRIVATE_KEY",
          "description": "Private key for Wompi",
          "isRequired": true,
          "format": "string",
          "isSecret": true
        },
        {
          "name": "WOMPI_EVENTS_SECRET",
          "description": "Events/webhook secret for signature validation",
          "isRequired": false,
          "format": "string",
          "isSecret": true
        }
      ]
    }
  ]
}
