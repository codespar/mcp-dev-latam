{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.codespar/mcp-tiny",
  "description": "MCP server for Tiny ERP — products, stock, categories, warehouses, price lists, orders, invoices, accounts payable/receivable",
  "repository": {
    "url": "https://github.com/codespar/mcp-dev-latam",
    "source": "github",
    "subfolder": "packages/erp/tiny"
  },
  "version": "0.2.1",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@codespar/mcp-tiny",
      "version": "0.2.1",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "TINY_API_TOKEN",
          "description": "API key for tiny",
          "isRequired": true,
          "format": "string",
          "isSecret": true
        }
      ]
    }
  ],
  "provider": {
    "homepage": "https://www.tiny.com.br",
    "logoUrl": "https://logo.clearbit.com/tiny.com.br",
    "logoFallback": "https://www.google.com/s2/favicons?domain=tiny.com.br&sz=128",
    "docsUrl": "https://tiny.com.br/info-api",
    "sandbox": {
      "available": false
    }
  }
}
