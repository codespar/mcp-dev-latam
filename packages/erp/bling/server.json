{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.codespar/mcp-bling",
  "description": "MCP server for Bling — ERP, products, orders, purchase orders, invoices (NF-e/NFS-e), stock, AR/AP, warehouses, webhooks",
  "repository": {
    "url": "https://github.com/codespar/mcp-dev-latam",
    "source": "github",
    "subfolder": "packages/erp/bling"
  },
  "version": "0.2.1",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@codespar/mcp-bling",
      "version": "0.2.1",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "BLING_ACCESS_TOKEN",
          "description": "API key for bling",
          "isRequired": true,
          "format": "string",
          "isSecret": true
        }
      ]
    }
  ],
  "provider": {
    "homepage": "https://www.bling.com.br",
    "logoUrl": "https://logo.clearbit.com/bling.com.br",
    "logoFallback": "https://www.google.com/s2/favicons?domain=bling.com.br&sz=128",
    "docsUrl": "https://developer.bling.com.br",
    "sandbox": {
      "available": false
    }
  }
}
