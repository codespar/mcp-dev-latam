{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.codespar/mcp-facturapi",
  "description": "FacturAPI — Mexican CFDI e-invoicing",
  "repository": {
    "url": "https://github.com/codespar/mcp-dev-latam",
    "source": "github",
    "subfolder": "packages/mexico/facturapi"
  },
  "version": "0.2.1",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@codespar/mcp-facturapi",
      "version": "0.2.1",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "FACTURAPI_API_KEY",
          "description": "API key for FacturAPI",
          "isRequired": true,
          "format": "string",
          "isSecret": true
        }
      ]
    }
  ],
  "provider": {
    "homepage": "https://www.facturapi.io",
    "logoUrl": "https://logo.clearbit.com/facturapi.io",
    "logoFallback": "https://www.google.com/s2/favicons?domain=facturapi.io&sz=128",
    "docsUrl": "https://docs.facturapi.io",
    "sandbox": {
      "available": true
    }
  }
}
