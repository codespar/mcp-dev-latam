{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.codespar/mcp-skydropx",
  "description": "Skydropx — Mexican multi-carrier shipping aggregator",
  "repository": {
    "url": "https://github.com/codespar/mcp-dev-latam",
    "source": "github",
    "subfolder": "packages/mexico/skydropx"
  },
  "version": "0.2.0",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@codespar/mcp-skydropx",
      "version": "0.2.0",
      "transport": { "type": "stdio" },
      "environmentVariables": [
        {
          "name": "SKYDROPX_API_TOKEN",
          "description": "API token for Skydropx",
          "isRequired": true,
          "format": "string",
          "isSecret": true
        }
      ]
    }
  ]
}
