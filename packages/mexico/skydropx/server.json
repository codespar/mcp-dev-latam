{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.codespar/mcp-skydropx",
  "description": "Skydropx — Mexican multi-carrier shipping aggregator",
  "repository": {
    "url": "https://github.com/codespar/mcp-dev-latam",
    "source": "github",
    "subfolder": "packages/mexico/skydropx"
  },
  "version": "0.2.1",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@codespar/mcp-skydropx",
      "version": "0.2.1",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "SKYDROPX_API_TOKEN",
          "description": "API token for Skydropx",
          "isRequired": true,
          "format": "string",
          "isSecret": true
        }
      ]
    }
  ],
  "provider": {
    "homepage": "https://www.skydropx.com",
    "logoUrl": "https://logo.clearbit.com/skydropx.com",
    "logoFallback": "https://www.google.com/s2/favicons?domain=skydropx.com&sz=128",
    "docsUrl": "https://skydropx.readme.io",
    "sandbox": {
      "available": true
    }
  }
}
