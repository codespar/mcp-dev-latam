{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.codespar/mcp-stp-spei",
  "description": "STP/SPEI — Mexican instant bank transfers",
  "repository": {
    "url": "https://github.com/codespar/mcp-dev-latam",
    "source": "github",
    "subfolder": "packages/mexico/stp-spei"
  },
  "version": "0.2.0-alpha.2",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@codespar/mcp-stp-spei",
      "version": "0.2.0-alpha.2",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "STP_API_KEY",
          "description": "API key for STP",
          "isRequired": true,
          "format": "string",
          "isSecret": true
        },
        {
          "name": "STP_COMPANY",
          "description": "Company identifier for STP",
          "isRequired": true,
          "format": "string",
          "isSecret": false
        }
      ]
    }
  ],
  "provider": {
    "homepage": "https://www.stpmex.com",
    "logoUrl": "https://logo.clearbit.com/stpmex.com",
    "logoFallback": "https://www.google.com/s2/favicons?domain=stpmex.com&sz=128",
    "docsUrl": "https://stpmex.com/docs",
    "sandbox": {
      "available": true
    }
  }
}
