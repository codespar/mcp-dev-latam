{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.codespar/mcp-stp-spei",
  "description": "STP/SPEI — Mexican instant bank transfers",
  "repository": {
    "url": "https://github.com/codespar/mcp-dev-latam",
    "source": "github",
    "subfolder": "packages/mexico/stp-spei"
  },
  "version": "0.2.0-alpha.1",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@codespar/mcp-stp-spei",
      "version": "0.2.0-alpha.1",
      "transport": { "type": "stdio" },
      "environmentVariables": [
        {
          "name": "STP_API_KEY",
          "description": "API key for STP",
          "isRequired": true,
          "format": "string",
          "isSecret": true
        },
        {
          "name": "STP_COMPANY",
          "description": "Company identifier for STP",
          "isRequired": true,
          "format": "string",
          "isSecret": false
        }
      ]
    }
  ]
}
