{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.codespar/mcp-bind-erp",
  "description": "Bind ERP — Mexican cloud ERP",
  "repository": {
    "url": "https://github.com/codespar/mcp-dev-latam",
    "source": "github",
    "subfolder": "packages/mexico/bind-erp"
  },
  "version": "0.2.0",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@codespar/mcp-bind-erp",
      "version": "0.2.0",
      "transport": { "type": "stdio" },
      "environmentVariables": [
        {
          "name": "BIND_API_KEY",
          "description": "API key for Bind ERP",
          "isRequired": true,
          "format": "string",
          "isSecret": true
        }
      ]
    }
  ]
}
