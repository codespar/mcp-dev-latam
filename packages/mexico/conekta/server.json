{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.codespar/mcp-conekta",
  "description": "Conekta — Mexican payment gateway (cards, OXXO cash, SPEI)",
  "repository": {
    "url": "https://github.com/codespar/mcp-dev-latam",
    "source": "github",
    "subfolder": "packages/mexico/conekta"
  },
  "version": "0.2.1",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@codespar/mcp-conekta",
      "version": "0.2.1",
      "transport": { "type": "stdio" },
      "environmentVariables": [
        {
          "name": "CONEKTA_API_KEY",
          "description": "API key for Conekta",
          "isRequired": true,
          "format": "string",
          "isSecret": true
        }
      ]
    }
  ]
}
