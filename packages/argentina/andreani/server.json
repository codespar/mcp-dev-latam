{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.codespar/mcp-andreani",
  "description": "Andreani — Argentine courier and logistics",
  "repository": {
    "url": "https://github.com/codespar/mcp-dev-latam",
    "source": "github",
    "subfolder": "packages/argentina/andreani"
  },
  "version": "0.2.0-alpha.2",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@codespar/mcp-andreani",
      "version": "0.2.0-alpha.2",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "ANDREANI_API_KEY",
          "description": "API key for Andreani",
          "isRequired": true,
          "format": "string",
          "isSecret": true
        },
        {
          "name": "ANDREANI_USER",
          "description": "Username for Andreani",
          "isRequired": true,
          "format": "string",
          "isSecret": false
        },
        {
          "name": "ANDREANI_PASSWORD",
          "description": "Password for Andreani",
          "isRequired": true,
          "format": "string",
          "isSecret": true
        }
      ]
    }
  ],
  "provider": {
    "homepage": "https://www.andreani.com",
    "logoUrl": "https://logo.clearbit.com/andreani.com",
    "logoFallback": "https://www.google.com/s2/favicons?domain=andreani.com&sz=128",
    "docsUrl": "https://developers.andreani.com",
    "sandbox": {
      "available": true
    }
  }
}
