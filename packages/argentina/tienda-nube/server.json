{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.codespar/mcp-tienda-nube",
  "description": "Tienda Nube — LATAM e-commerce platform (Argentine-founded)",
  "repository": {
    "url": "https://github.com/codespar/mcp-dev-latam",
    "source": "github",
    "subfolder": "packages/argentina/tienda-nube"
  },
  "version": "0.2.1",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@codespar/mcp-tienda-nube",
      "version": "0.2.1",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "TIENDANUBE_ACCESS_TOKEN",
          "description": "Access token for Tienda Nube",
          "isRequired": true,
          "format": "string",
          "isSecret": true
        },
        {
          "name": "TIENDANUBE_STORE_ID",
          "description": "Store identifier",
          "isRequired": true,
          "format": "string",
          "isSecret": false
        }
      ]
    }
  ],
  "provider": {
    "homepage": "https://www.tiendanube.com",
    "logoUrl": "https://logo.clearbit.com/tiendanube.com",
    "logoFallback": "https://www.google.com/s2/favicons?domain=tiendanube.com&sz=128",
    "docsUrl": "https://tiendanube.github.io",
    "sandbox": {
      "available": true
    }
  }
}
