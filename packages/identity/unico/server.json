{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.codespar/mcp-unico",
  "description": "MCP server for Unico — Brazilian identity verification & KYC (IDCloud, IDPay, IDCheck, Sign). CPF/CNPJ, document OCR, face match, liveness, PEP/watchlists, processes, webhooks, Unico Score.",
  "repository": {
    "url": "https://github.com/codespar/mcp-dev-latam",
    "source": "github",
    "subfolder": "packages/identity/unico"
  },
  "version": "0.2.0-alpha.2",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@codespar/mcp-unico",
      "version": "0.2.0-alpha.2",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "UNICO_CLIENT_ID",
          "description": "Unico OAuth client_id",
          "isRequired": true,
          "format": "string",
          "isSecret": false
        },
        {
          "name": "UNICO_CLIENT_SECRET",
          "description": "Unico OAuth client_secret",
          "isRequired": true,
          "format": "string",
          "isSecret": true
        },
        {
          "name": "UNICO_ENV",
          "description": "Environment: 'sandbox' or 'production'. Defaults to 'sandbox'.",
          "isRequired": false,
          "format": "string",
          "isSecret": false
        },
        {
          "name": "UNICO_BASE_URL",
          "description": "Optional override for the IDCloud/IDPay/IDCheck API base URL. Defaults to https://api.unico.co.",
          "isRequired": false,
          "format": "string",
          "isSecret": false
        },
        {
          "name": "UNICO_AUTH_URL",
          "description": "Optional override for the OAuth token endpoint base URL. Defaults to https://auth.unico.co.",
          "isRequired": false,
          "format": "string",
          "isSecret": false
        }
      ]
    }
  ],
  "provider": {
    "homepage": "https://www.unico.io",
    "logoUrl": "https://logo.clearbit.com/unico.io",
    "logoFallback": "https://www.google.com/s2/favicons?domain=unico.io&sz=128",
    "docsUrl": "https://docs.unico.io",
    "sandbox": {
      "available": true
    }
  }
}
