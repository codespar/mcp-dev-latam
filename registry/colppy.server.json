{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.codespar/mcp-colppy",
  "description": "Colppy — Argentine cloud accounting + AFIP invoicing",
  "repository": {
    "url": "https://github.com/codespar/mcp-dev-latam",
    "source": "github",
    "subfolder": "packages/argentina/colppy"
  },
  "version": "0.1.0",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@codespar/mcp-colppy",
      "version": "0.1.0",
      "transport": { "type": "stdio" },
      "environmentVariables": [
        {
          "name": "COLPPY_API_KEY",
          "description": "API key for Colppy",
          "isRequired": true,
          "format": "string",
          "isSecret": true
        },
        {
          "name": "COLPPY_COMPANY_ID",
          "description": "Company identifier",
          "isRequired": true,
          "format": "string",
          "isSecret": false
        }
      ]
    }
  ]
}
